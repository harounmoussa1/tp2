@model IEnumerable<WebApplication1.Models.Cinema.Movie>
@{ ViewData["Title"] = "Films et leurs Producteurs"; }
<h1>Films et leurs Producteurs</h1>
<table class="table">
    <thead>
        <tr>
            <th>Titre du Film</th>
            <th>Genre</th>
            <th>Nom Producteur</th>
            <th>Nationalité Producteur</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Genre</td>
            <td>@item.Producer?.Name</td>
            <td>@item.Producer?.Nationality</td>
        </tr>
    }
    </tbody>
</table>
