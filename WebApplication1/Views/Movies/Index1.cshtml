@model IEnumerable<WebApplication1.Models.Cinema.ProdMovie>
@{ ViewData["Title"] = "Films et Producteurs (ViewModel)"; }
<h1>Films et Producteurs — Via ViewModel</h1>
<table class="table">
    <thead>
        <tr>
            <th>Titre</th><th>Genre</th>
            <th>Producteur</th><th>Nationalité</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.mTitle</td>
            <td>@item.mGenre</td>
            <td>@item.pName</td>
            <td>@item.pNat</td>
        </tr>
    }
    </tbody>
</table>
